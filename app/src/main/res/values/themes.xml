<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── BASE APP THEME ── -->
    <style name="Base.Theme.HabitFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/primary_green</item>
        <item name="colorTertiary">@color/accent_purple</item>
        <item name="android:statusBarColor">@color/dark_bg_primary</item>
        <item name="android:navigationBarColor">@color/dark_nav_bg</item>
        <item name="android:windowBackground">@color/dark_bg_primary</item>
    </style>

    <style name="Theme.HabitFlow" parent="Base.Theme.HabitFlow" />

    <style name="Theme.HabitFlow.Dark" parent="Base.Theme.HabitFlow" />

    <style name="Theme.HabitFlow.Light" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <style name="Theme.HabitFlow.Ocean" parent="Base.Theme.HabitFlow">
        <item name="android:windowBackground">#0A1628</item>
    </style>

    <style name="Theme.HabitFlow.Sunset" parent="Base.Theme.HabitFlow">
        <item name="android:windowBackground">#1A0A0A</item>
    </style>

    <style name="Theme.HabitFlow.Forest" parent="Base.Theme.HabitFlow">
        <item name="android:windowBackground">#0A150A</item>
    </style>

    <style name="Theme.HabitFlow.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/primary_blue</item>
        <item name="android:statusBarColor">@color/primary_blue</item>
        <item name="android:navigationBarColor">@color/primary_blue</item>
    </style>

    <!-- ── WIDGET STYLES ── -->

    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_blue</item>
        <item name="android:textColor">@color/primary_blue</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="InputField" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxBackgroundColor">@color/dark_bg_elevated</item>
    </style>

    <style name="FilterChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="chipBackgroundColor">@color/dark_bg_card</item>
        <item name="android:textColor">@color/dark_text_secondary</item>
        <item name="chipStrokeWidth">0dp</item>
    </style>

    <style name="FabShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <style name="NavIndicator" parent="">
        <item name="android:color">@color/primary_blue</item>
    </style>

</resources>