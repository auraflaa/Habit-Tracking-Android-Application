<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/customWindowBackground">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="24dp" android:paddingTop="32dp" android:paddingBottom="24dp">

        <TextView android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/calendar_title"
            style="@style/AppTitleLarge"
            android:textColor="?attr/customTextPrimary"/>

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:background="@drawable/bg_card_outlined"
            android:padding="4dp">

            <ImageButton android:id="@+id/btn_prev"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_left" app:tint="?attr/customTextSecondary"
                android:contentDescription="Previous month"/>

            <TextView android:id="@+id/tv_month"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="April 2024"
                android:textColor="?attr/customTextPrimary" android:textSize="14sp"
                android:textStyle="bold" android:paddingHorizontal="8dp"/>

            <ImageButton android:id="@+id/btn_next"
                android:layout_width="32dp" android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_chevron_right" app:tint="?attr/customTextSecondary"
                android:contentDescription="Next month"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Calendar Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="24dp" app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/customCardBackground">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Day-of-week headers -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:paddingBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="S" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="M" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="T" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="W" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="T" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="F" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="S" android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                    android:textStyle="bold" android:gravity="center" android:alpha="0.5"/>
            </LinearLayout>

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_calendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="7"
                app:rowCount="6"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Selected Day Info -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="24dp" android:paddingTop="32dp" android:paddingBottom="16dp">

        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical">
            <TextView android:id="@+id/tv_selected_date"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Today"
                style="@style/AppTitleMedium"
                android:textColor="?attr/customTextPrimary"/>
            <TextView android:id="@+id/tv_selected_rate"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0% completion"
                android:textColor="?attr/customTextSecondary" android:textSize="13sp"
                android:layout_marginTop="2dp" android:alpha="0.7"/>
        </LinearLayout>

        <!-- Legend -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_heatmap_0" android:layout_marginEnd="4dp"/>
            <View android:layout_width="8dp" android:layout_height="8dp"
                android:background="@drawable/bg_heatmap_3" android:alpha="0.8"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Habits List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_day_habits"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"/>

</LinearLayout>