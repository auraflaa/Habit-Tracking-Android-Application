<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/customWindowBackground"
    android:scrollbars="none">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingBottom="32dp">

        <!-- Header -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/progress_title"
            android:textColor="?attr/customTextPrimary" android:textSize="28sp"
            android:textStyle="bold" android:paddingHorizontal="24dp"
            android:paddingTop="32dp" android:paddingBottom="20dp"/>

        <!-- Stats row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingHorizontal="16dp"
            android:layout_marginBottom="20dp">

            <!-- Best Streak -->
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginHorizontal="6dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/customCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_best_streak"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/brand_fire" android:textSize="28sp"
                        android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_best_streak"
                        android:textColor="?attr/customTextSecondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Completions -->
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginHorizontal="6dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/customCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✅" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_total"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/brand_green" android:textSize="28sp"
                        android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_completed"
                        android:textColor="?attr/customTextSecondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Current Streak -->
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginHorizontal="6dp"
                app:cardCornerRadius="20dp" app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/customCardBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡" android:textSize="24sp"/>
                    <TextView android:id="@+id/tv_current_streak"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/brand_blue" android:textSize="28sp"
                        android:textStyle="bold" android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/label_current"
                        android:textColor="?attr/customTextSecondary" android:textSize="11sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Scope tabs (Day / Week / Month) -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_scope"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/customCardBackground"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabSelectedTextColor="?attr/customTextPrimary"
            app:tabTextColor="?attr/customTextSecondary"
            app:tabIndicatorColor="@color/brand_blue"
            app:tabIndicatorHeight="2dp"
            app:tabRippleColor="@color/transparent">
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Day"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Week"/>
            <com.google.android.material.tabs.TabItem android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Month"/>
        </com.google.android.material.tabs.TabLayout>

        <!-- Bar chart card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="200dp"
            android:layout_marginHorizontal="24dp" android:layout_marginBottom="20dp"
            app:cardCornerRadius="20dp" app:cardElevation="0dp"
            app:cardBackgroundColor="?attr/customCardBackground">

            <com.habitflow.views.BarChartView
                android:id="@+id/bar_chart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"/>
        </androidx.cardview.widget.CardView>

        <!-- Habit breakdown list -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_breakdown"
            android:textColor="?attr/customTextPrimary" android:textSize="18sp"
            android:textStyle="bold" android:paddingHorizontal="24dp"
            android:paddingBottom="12dp"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_breakdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:paddingHorizontal="16dp"/>

        <!-- Activity grid (heatmap) -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_heatmap"
            android:textColor="?attr/customTextPrimary" android:textSize="18sp"
            android:textStyle="bold" android:paddingHorizontal="24dp"
            android:paddingTop="20dp" android:paddingBottom="12dp"/>

        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:fillViewport="true">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:paddingHorizontal="24dp">
                <com.habitflow.views.HeatmapView
                    android:id="@+id/heatmap"
                    android:layout_width="wrap_content"
                    android:layout_height="80dp"/>
            </LinearLayout>
        </HorizontalScrollView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>