<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="40dp">

    <!-- Handle -->
    <View android:layout_width="32dp" android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp" android:layout_marginBottom="8dp"
        android:background="@drawable/bg_sheet_handle"
        android:alpha="0.2"/>

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingHorizontal="24dp" android:paddingVertical="16dp">

        <TextView android:id="@+id/tv_sheet_title"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/add_habit_title"
            style="@style/AppTitleMedium"
            android:textColor="?attr/customTextPrimary"/>

        <ImageButton android:id="@+id/btn_close"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:tint="?attr/customTextSecondary"
            android:contentDescription="Close"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingHorizontal="24dp">

            <!-- Habit name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_name"
                style="@style/InputField"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_habit_name" android:layout_marginBottom="16dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:textColor="?attr/customTextPrimary"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_desc"
                style="@style/InputField"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/hint_habit_desc" android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_desc"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="2" android:maxLines="3"
                    android:textColor="?attr/customTextPrimary"
                    android:textSize="14sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Section Label -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Choose Icon"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="24dp">
                <LinearLayout android:id="@+id/ll_emojis"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Habit Color"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:scrollbars="none" android:layout_marginBottom="24dp">
                <LinearLayout android:id="@+id/ll_colors"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </HorizontalScrollView>

            <!-- Category -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_category"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:singleSelection="true" app:selectionRequired="true"
                android:layout_marginBottom="24dp"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip android:id="@+id/chip_fitness"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="💪 Fitness" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_learning"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="📚 Learning"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_wellness"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🧘 Wellness"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Priority -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Priority"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_priority"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:singleSelection="true" app:selectionRequired="true"
                android:layout_marginBottom="24dp"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip android:id="@+id/chip_low"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Low"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_medium"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Medium" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_high"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="High"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Time of Day -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Best Time"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chips_segment"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:singleSelection="true" app:selectionRequired="true"
                android:layout_marginBottom="24dp"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip android:id="@+id/chip_morning"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🌅 Morning" android:checked="true"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_afternoon"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="☀️ Afternoon"/>
                <com.google.android.material.chip.Chip android:id="@+id/chip_evening"
                    style="@style/FilterChip" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="🌙 Evening"/>
            </com.google.android.material.chip.ChipGroup>

            <!-- Checklist Section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Checklist"
                android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                android:textStyle="bold" android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/ll_checklist_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_checklist_item"
                style="@style/Widget.Material3.Button.TextButton.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Item"
                app:icon="@drawable/ic_add"
                android:layout_marginBottom="24dp"/>

            <!-- Reminder Card -->
            <LinearLayout android:id="@+id/row_reminder_time"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bg_card_outlined"
                android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                android:layout_marginBottom="32dp"
                android:clickable="true" android:focusable="true">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="⏰" android:textSize="18sp" android:layout_marginEnd="12dp"/>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Daily Reminder"
                        android:textColor="?attr/customTextPrimary" android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_reminder_time"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="08:00 AM"
                        android:textColor="?attr/customTextSecondary" android:textSize="12sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_reminder"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    app:useMaterialThemeColors="true"/>
            </LinearLayout>

            <!-- Save button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                style="@style/PrimaryButton"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:text="Create Habit"/>

            <!-- Delete button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                android:layout_width="match_parent" android:layout_height="48dp"
                android:text="Delete Habit"
                android:textColor="@color/error_red"
                android:background="@android:color/transparent"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:textAllCaps="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>