<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/customCardBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Emoji container -->
        <View android:id="@+id/view_accent"
            android:layout_width="48dp" android:layout_height="48dp"
            android:background="@drawable/bg_icon_container"
            android:visibility="gone"/>

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_container"
            android:layout_marginEnd="16dp">

            <TextView android:id="@+id/tv_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="💪"
                android:textSize="22sp"/>

            <View android:id="@+id/view_priority"
                android:layout_width="8dp" android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_margin="4dp"/>
        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/customTextPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="Workout"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <TextView android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/customTextSecondary"
                    android:text="Health"
                    android:alpha="0.7"/>

                <View android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="8dp"
                    android:background="@drawable/bg_dot_separator"
                    android:alpha="0.3"/>

                <TextView android:id="@+id/tv_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_fire"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:text="5 day streak"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Check action -->
        <FrameLayout android:id="@+id/btn_check"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_check_empty"
            android:clickable="true"
            android:focusable="true">

            <ImageView android:id="@+id/iv_check_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                app:tint="@color/white"
                android:visibility="gone"/>
        </FrameLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>