<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="?attr/customCardBackground">

    <!-- Left color accent bar -->
    <View android:id="@+id/view_accent"
        android:layout_width="4dp" android:layout_height="match_parent"
        android:background="@color/brand_blue"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- Emoji icon -->
        <LinearLayout android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:background="@drawable/bg_icon_container"
            android:layout_marginEnd="14dp">
            <TextView android:id="@+id/tv_emoji"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💪" android:textSize="22sp"/>
        </LinearLayout>

        <!-- Info -->
        <LinearLayout android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:orientation="vertical">

            <!-- Name + priority dot -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/tv_name"
                    android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/customTextPrimary" android:textSize="15sp"
                    android:textStyle="bold"/>
                <View android:id="@+id/view_priority"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:background="@drawable/bg_check_done"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <!-- Category + streak + time -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginTop="5dp">

                <TextView android:id="@+id/tv_category"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textSize="11sp" android:textStyle="bold"
                    android:background="@drawable/bg_category_chip"
                    android:paddingHorizontal="8dp" android:paddingVertical="2dp"
                    android:textColor="?attr/customTextSecondary"/>

                <TextView android:id="@+id/tv_streak"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/brand_fire" android:textSize="11sp"
                    android:layout_marginStart="8dp"/>

                <TextView android:id="@+id/tv_time"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="?attr/customTextSecondary" android:textSize="11sp"
                    android:layout_marginStart="8dp" android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Check button -->
        <FrameLayout android:id="@+id/btn_check"
            android:layout_width="44dp" android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_check_empty"
            android:clickable="true" android:focusable="true">

            <ImageView android:id="@+id/iv_check_icon"
                android:layout_width="20dp" android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check"
                android:tint="@color/white"
                android:visibility="gone"/>
        </FrameLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>